# All variables are OPTIONAL. The site builds and deploys with none of them.

# Clerk (enables Sign in + protected /dashboard when BOTH are set)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (future production data layer; unused by the demo dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Formspree form ID for the pilot waitlist form (e.g. abcdwxyz).
# Without it, the waitlist CTA falls back to a mailto link.
NEXT_PUBLIC_FORMSPREE_FORM_ID=
