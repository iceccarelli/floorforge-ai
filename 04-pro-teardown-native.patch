+"use client";
+
+import React, { useEffect, useState, Suspense } from "react";
+import { Canvas } from "@react-three/fiber";
+import {
+  OrbitControls,
+  Environment,
+  Lightformer,
+  ContactShadows,
+} from "@react-three/drei";
+import {
+  Boxes,
+  Layers,
+  RotateCw,
+  RefreshCw,
+  ScanLine,
+} from "lucide-react";
+import { getRobot, type RobotSpec } from "@/lib/robots";
+import { useSim } from "@/lib/simStore";
+import RobotMesh from "@/components/simulator/RobotMesh";
+
+/** Honest, concept-level descriptions of the internals the model actually
+ *  renders for each platform — used for the annotated parts legend. */
+function partsFor(id: string): { label: string; note: string }[] {
+  switch (id) {
+    case "sand":
+      return [
+        { label: "Planetary drum", note: "ribbed abrasive · 36→120 grit" },
+        { label: "Brushless motor + rotor", note: "revealed in cutaway" },
+        { label: "Reduction gear pair", note: "meshing spur gears" },
+        { label: "Dust shroud + hose", note: "routes to HEPA canister" },
+      ];
+    case "edge":
+      return [
+        { label: "Oscillating disc head", note: "edge & transition sanding" },
+        { label: "Offset follow arm", note: "reaches the wall line" },
+        { label: "Guard skirt", note: "contains debris" },
+      ];
+    case "coat":
+      return [
+        { label: "Fluid tank", note: "stain / poly reservoir" },
+        { label: "Feed line", note: "to the applicator" },
+        { label: "Applicator bar", note: "even film build" },
+        { label: "Wet-film sheen", note: "freshly laid finish" },
+      ];
+    case "lay":
+      return [
+        { label: "Gantry + gripper", note: "picks & sets each plank" },
+        { label: "Plank magazine", note: "staged material feed" },
+        { label: "Alignment head", note: "vision-indexed rows" },
+      ];
+    case "scan":
+      return [
+        { label: "LiDAR dome", note: "rotating flatness sweep" },
+        { label: "Scan emitter ring", note: "active while surveying" },
+        { label: "Forward camera pods", note: "coverage QA" },
+        { label: "Sensor mast", note: "elevated vantage" },
+      ];
+    default:
+      return [];
+  }
+}
+
+function Scene({ robot, autoRotate }: { robot: RobotSpec; autoRotate: boolean }) {
+  return (
+    <>
+      <ambientLight intensity={0.4} />
+      <directionalLight position={[4, 6, 3]} intensity={1.6} castShadow />
+      <directionalLight position={[-5, 3, -4]} intensity={0.5} color="#bcd0ff" />
+
+      {/* in-engine reflections — no network fetch, offline-safe */}
+      <Environment resolution={128} frames={1}>
+        <Lightformer intensity={2.2} position={[0, 4, 2]} scale={[6, 3, 1]} color="#fff6e8" />
+        <Lightformer intensity={1.4} position={[4, 2, -3]} scale={[3, 3, 1]} color="#dce8ff" />
+        <Lightformer intensity={1} position={[-4, 1, 2]} scale={[3, 3, 1]} color="#ffffff" />
+      </Environment>
+
+      {/* turntable pedestal */}
+      <mesh position={[0, -0.006, 0]} rotation={[0, 0, 0]}>
+        <cylinderGeometry args={[1.15, 1.2, 0.012, 64]} />
+        <meshStandardMaterial color="#12161f" metalness={0.6} roughness={0.35} envMapIntensity={0.6} />
+      </mesh>
+      <mesh position={[0, 0.002, 0]}>
+        <torusGeometry args={[1.15, 0.006, 8, 80]} />
+        <meshStandardMaterial color={robot.color} emissive={robot.color} emissiveIntensity={0.5} />
+      </mesh>
+
+      <ContactShadows position={[0, 0.001, 0]} opacity={0.5} scale={5} blur={2.4} far={2} />
+
+      <group position={[0, 0, 0]}>
+        <RobotMesh robot={robot} animate />
+      </group>
+
+      <OrbitControls
+        enablePan={false}
+        autoRotate={autoRotate}
+        autoRotateSpeed={0.9}
+        minDistance={1.4}
+        maxDistance={6}
+        maxPolarAngle={Math.PI / 1.9}
+        target={[0, 0.3, 0]}
+        enableDamping
+      />
+    </>
+  );
+}
+
+export default function ProTeardown({
+  robotId,
+  roomW,
+  roomL,
+}: {
+  robotId: string;
+  roomW: string;
+  roomL: string;
+}) {
+  const robot = getRobot(robotId);
+  const exploded = useSim((s) => s.exploded);
+  const cutaway = useSim((s) => s.cutaway);
+  const setExploded = useSim((s) => s.setExploded);
+  const toggleCutaway = useSim((s) => s.toggleCutaway);
+  const [autoRotate, setAutoRotate] = useState(true);
+
+  // Enter with a clean, assembled machine; leave the store tidy on exit so
+  // navigating back to /simulator doesn't inherit teardown inspection state.
+  useEffect(() => {
+    useSim.setState({ exploded: 0, cutaway: false });
+    return () => useSim.setState({ exploded: 0, cutaway: false });
+  }, [robotId]);
+
+  const reset = () => {
+    setExploded(0);
+    if (cutaway) toggleCutaway();
+  };
+
+  const parts = partsFor(robot.id);
+
+  return (
+    <div className="relative aspect-video w-full overflow-hidden rounded-2xl border border-border bg-[#0b0e14]">
+      {/* subtle studio vignette */}
+      <div
+        className="pointer-events-none absolute inset-0 z-[1]"
+        style={{
+          background:
+            "radial-gradient(120% 90% at 50% 12%, rgba(255,255,255,0.06), transparent 55%)",
+        }}
+      />
+
+      <Canvas
+        shadows
+        dpr={[1, 1.75]}
+        camera={{ position: [1.7, 1.15, 1.9], fov: 40 }}
+        className="h-full w-full"
+        aria-label={`High-fidelity 3D teardown of the ${robot.name}`}
+      >
+        <color attach="background" args={["#0b0e14"]} />
+        <Suspense fallback={null}>
+          <Scene robot={robot} autoRotate={autoRotate} />
+        </Suspense>
+      </Canvas>
+
+      {/* title chip */}
+      <div className="pointer-events-none absolute left-3 top-3 z-10 rounded-xl border border-white/10 bg-black/40 px-3 py-2 backdrop-blur-sm">
+        <p className="flex items-center gap-2 text-sm font-semibold text-white">
+          <span
+            className="inline-block h-2.5 w-2.5 rounded-full"
+            style={{ background: robot.color }}
+          />
+          {robot.name}
+        </p>
+        <p className="text-[11px] text-white/60">{robot.role}</p>
+      </div>
+
+      {/* parts legend */}
+      {parts.length > 0 && (
+        <div className="pointer-events-none absolute right-3 top-3 z-10 hidden w-[210px] rounded-xl border border-white/10 bg-black/40 p-3 backdrop-blur-sm sm:block">
+          <p className="mb-2 flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-wide text-white/70">
+            <ScanLine className="h-3.5 w-3.5" /> Internals
+          </p>
+          <ul className="space-y-1.5">
+            {parts.map((p) => (
+              <li key={p.label} className="flex gap-2">
+                <span
+                  className="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full"
+                  style={{ background: robot.color }}
+                />
+                <span className="min-w-0">
+                  <span className="block text-[12px] font-medium text-white">
+                    {p.label}
+                  </span>
+                  <span className="block text-[10px] leading-tight text-white/55">
+                    {p.note}
+                  </span>
+                </span>
+              </li>
+            ))}
+          </ul>
+        </div>
+      )}
+
+      {/* control dock */}
+      <div className="absolute inset-x-3 bottom-3 z-10 rounded-xl border border-white/10 bg-black/45 p-3 backdrop-blur-md">
+        <div className="flex flex-col gap-3 sm:flex-row sm:items-center">
+          {/* exploded */}
+          <div className="min-w-0 flex-1">
+            <div className="mb-1 flex items-center justify-between">
+              <label
+                htmlFor="pt-explode"
+                className="flex items-center gap-1.5 text-[11px] font-semibold text-white"
+              >
+                <Boxes className="h-3.5 w-3.5" /> Exploded view
+              </label>
+              <span className="font-mono text-[11px] text-white/60">
+                {Math.round(exploded * 100)}%
+              </span>
+            </div>
+            <input
+              id="pt-explode"
+              type="range"
+              min={0}
+              max={1}
+              step={0.01}
+              value={exploded}
+              onChange={(e) => setExploded(Number(e.target.value))}
+              className="w-full accent-[var(--accent)]"
+            />
+          </div>
+
+          {/* buttons */}
+          <div className="flex shrink-0 gap-2">
+            <button
+              onClick={toggleCutaway}
+              aria-pressed={cutaway}
+              className={`flex items-center gap-1.5 rounded-lg border px-3 py-2 text-xs font-medium transition-colors ${
+                cutaway
+                  ? "border-accent bg-accent text-white"
+                  : "border-white/15 bg-white/5 text-white/80 hover:bg-white/10"
+              }`}
+            >
+              <Layers className="h-3.5 w-3.5" /> Cutaway
+            </button>
+            <button
+              onClick={() => setAutoRotate((v) => !v)}
+              aria-pressed={autoRotate}
+              className={`flex items-center gap-1.5 rounded-lg border px-3 py-2 text-xs font-medium transition-colors ${
+                autoRotate
+                  ? "border-accent bg-accent text-white"
+                  : "border-white/15 bg-white/5 text-white/80 hover:bg-white/10"
+              }`}
+            >
+              <RotateCw className="h-3.5 w-3.5" /> Spin
+            </button>
+            <button
+              onClick={reset}
+              className="flex items-center gap-1.5 rounded-lg border border-white/15 bg-white/5 px-3 py-2 text-xs font-medium text-white/80 transition-colors hover:bg-white/10"
+            >
+              <RefreshCw className="h-3.5 w-3.5" /> Reset
+            </button>
+          </div>
+        </div>
+        <p className="mt-2 text-[10px] leading-tight text-white/45">
+          Concept teardown for a {roomW}×{roomL} m job · drag to orbit · scroll to
+          zoom. Geometry shows how the machine is designed to work — not telemetry
+          from shipping hardware.
+        </p>
+      </div>
+    </div>
+  );
+}
