new file mode 100644
index 0000000..ca4b984
--- /dev/null
+++ b/app/robots.ts
@@ -0,0 +1,17 @@
+import type { MetadataRoute } from "next";
+
+const SITE_URL =
+  process.env.NEXT_PUBLIC_SITE_URL ?? "https://floorforge-ai.vercel.app";
+
+export default function robots(): MetadataRoute.Robots {
+  return {
+    rules: {
+      userAgent: "*",
+      allow: "/",
+      // The dashboard is gated app surface, not marketing content.
+      disallow: ["/dashboard"],
+    },
+    sitemap: `${SITE_URL}/sitemap.xml`,
+    host: SITE_URL,
+  };
+}
diff --git a/app/sitemap.ts b/app/sitemap.ts
new file mode 100644
index 0000000..7970260
--- /dev/null
+++ b/app/sitemap.ts
@@ -0,0 +1,17 @@
+import type { MetadataRoute } from "next";
+
+const SITE_URL =
+  process.env.NEXT_PUBLIC_SITE_URL ?? "https://floorforge-ai.vercel.app";
+
+export default function sitemap(): MetadataRoute.Sitemap {
+  const lastModified = new Date();
+  // Single-page marketing site: the anchor sections are the meaningful URLs.
+  return [
+    { url: SITE_URL, lastModified, changeFrequency: "weekly", priority: 1 },
+    { url: `${SITE_URL}/#how-it-works`, lastModified, changeFrequency: "monthly", priority: 0.8 },
+    { url: `${SITE_URL}/#features`, lastModified, changeFrequency: "monthly", priority: 0.7 },
+    { url: `${SITE_URL}/#pricing`, lastModified, changeFrequency: "monthly", priority: 0.7 },
+    { url: `${SITE_URL}/#faq`, lastModified, changeFrequency: "monthly", priority: 0.6 },
+    { url: `${SITE_URL}/#waitlist`, lastModified, changeFrequency: "monthly", priority: 0.9 },
+  ];
+}
