index 0000000..4c0c4f7
--- /dev/null
+++ b/components/FAQ.tsx
@@ -0,0 +1,85 @@
+import React from "react";
+
+/**
+ * Objection-handling FAQ. This is the honest version of a "trust overhaul":
+ * instead of fabricated testimonials or job counters, it answers the questions
+ * a real contractor/architect actually asks before trusting a pre-launch
+ * robotics vendor. Every answer must stay true to the current stage.
+ *
+ * EDIT the answers below to match your real pilot terms before launch —
+ * especially "Who's behind FloorForge?" and anything touching liability.
+ */
+const faqs: { q: string; a: string }[] = [
+  {
+    q: "Is FloorForge available to book today?",
+    a: "Not yet. FloorForge is in active development and we're recruiting a small group of refinishing operations for the pilot program. Pilot partners help define requirements and get preferential launch terms. Nothing on this site describes a shipped, bookable service.",
+  },
+  {
+    q: "What happens if a robot damages a floor during a job?",
+    a: "This is the first question every serious operator asks, so we don't leave it implicit. Liability, insurance, and on-site human-oversight requirements are written explicitly into each pilot agreement before any robot touches a real floor — and early jobs run alongside your existing crew, not instead of it.",
+  },
+  {
+    q: "How is this different from a skilled crew with a good sander?",
+    a: "The goal isn't to beat a great crew on a single perfect floor — it's consistency and documentation. Every pass, grit change, dust reading, and finish measurement is logged into a per-job report you can hand to the GC or property manager. The value is a predictable, documented result on every job, not a heroic one.",
+  },
+  {
+    q: "Do I still need my crew, or does this replace them?",
+    a: "You still need skilled people. Edging is semi-autonomous with a human-oversight mode, and someone runs the plan, handles setup, and owns the finish. FloorForge is designed to make an experienced crew faster and more consistent — think of your people as operators of the system, not competitors to it.",
+  },
+  {
+    q: "What's actually built today versus what's on the roadmap?",
+    a: "The software core — job planning, orchestration, and reporting — is what's furthest along. The hardware specs described on this site (low-profile sanders, dust systems, edge sensing) are design targets guiding development, and they're labeled that way throughout. Pilot feedback decides what gets built first.",
+  },
+  {
+    q: "Who's behind FloorForge?",
+    // EDIT ME: replace with your real, verifiable background before launch.
+    a: "FloorForge is built by an engineering team working in industrial robotics and automation. If you're evaluating us for a pilot, we're glad to walk you through our background and current progress on a direct call — that transparency is part of how the pilot works.",
+  },
+];
+
+export default function FAQ() {
+  const faqJsonLd = {
+    "@context": "https://schema.org",
+    "@type": "FAQPage",
+    mainEntity: faqs.map((f) => ({
+      "@type": "Question",
+      name: f.q,
+      acceptedAnswer: { "@type": "Answer", text: f.a },
+    })),
+  };
+
+  return (
+    <section id="faq" className="section max-w-3xl mx-auto px-6 py-20">
+      <div className="text-center mb-12">
+        <div className="text-accent text-xs tracking-[3px] font-semibold mb-2">
+          BEFORE YOU ASK
+        </div>
+        <h2 className="text-3xl sm:text-4xl lg:text-5xl tracking-[-0.03em] font-semibold">
+          The questions serious operators ask.
+        </h2>
+      </div>
+
+      <div className="divide-y divide-border rounded-2xl border bg-white">
+        {faqs.map((faq, i) => (
+          <details key={i} className="group px-6 py-5 [&_summary::-webkit-details-marker]:hidden">
+            <summary className="flex cursor-pointer items-center justify-between gap-4 text-lg font-semibold tracking-tight list-none focus-visible:outline-2 focus-visible:outline-accent rounded-md">
+              {faq.q}
+              <span
+                aria-hidden="true"
+                className="flex-shrink-0 text-accent text-2xl leading-none transition-transform duration-200 group-open:rotate-45"
+              >
+                +
+              </span>
+            </summary>
+            <p className="mt-4 text-muted-foreground leading-relaxed">{faq.a}</p>
+          </details>
+        ))}
+      </div>
+
+      <script
+        type="application/ld+json"
+        dangerouslySetInnerHTML={{ __html: JSON.stringify(faqJsonLd) }}
+      />
+    </section>
+  );
+}
